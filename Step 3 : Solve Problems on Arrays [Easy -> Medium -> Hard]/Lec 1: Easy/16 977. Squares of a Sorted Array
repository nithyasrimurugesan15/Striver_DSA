class Solution {
    public int[] sortedSquares(int[] nums) {
        int[] ans= new int[nums.length];
        int s=0;
        int e=nums.length-1;
        int k=nums.length-1;
        while(s<=e) {
            if((Math.abs(nums[s]))<nums[e]) {
                ans[k]=nums[e]*nums[e];
                e--;
            }
            else {
                ans[k]=nums[s]*nums[s];
                s++;
            }
            k--;
        }
        return ans;

        
    }
}
