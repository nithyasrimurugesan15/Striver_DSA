https://leetcode.com/problems/max-consecutive-ones-iii/description/

class Solution {
    public int longestOnes(int[] nums, int k) {

        int j=0,i=0;
        int cnt=0;
        int mxl=0;
        while(j<nums.length){
            if(nums[j]==0) {
                cnt++;

            }

            while(cnt>k) {
                if(nums[i]==0){
                    cnt--;
                }
                i++;
            }
            

            mxl =  Math.max(mxl,j-i+1);
            j++;

        }
        return mxl;
    }
}
