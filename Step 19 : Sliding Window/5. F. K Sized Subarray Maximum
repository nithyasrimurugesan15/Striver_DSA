class Solution {
    public ArrayList<Integer> maxOfSubarrays(int[] arr, int k) {
        // code here
        ArrayList<Integer> res  = new ArrayList<>();
        Deque<Integer> dq = new ArrayDeque<>();
        int i=0,j=0;
        while(j<arr.length) {
            while(!dq.isEmpty() && arr[dq.peekLast()] < arr[j]) {
                dq.pollLast();
            }
            dq.addLast(j);
            if(dq.peekFirst()<i) {
                dq.pollFirst();
            }
            if(j-i+1==k) {
                res.add(arr[dq.peekFirst()]);
                i++;
            }
            j++;
        }
            
        
        return res;
    }
}
