https://leetcode.com/problems/maximum-average-subarray-i/description/

class Solution {
    public double findMaxAverage(int[] nums, int k) {

        double mavg=0;
        double avg=0;
        double sum=0;
        for(int i=0;i<k;i++) {
            sum+=nums[i];
        }
        mavg=sum/k;
        for(int i=1;i<nums.length-k+1;i++) {
            sum=sum-nums[i-1]+nums[i+k-1];
            avg=sum/k;
            mavg=Math.max(mavg,avg);
        }
        return mavg;
    }
}
